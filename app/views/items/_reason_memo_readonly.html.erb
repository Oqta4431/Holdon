<div class="relative bg-base-200 rounded-box p-3">
  <div class="absolute inset-y-3 left-1/2 w-px bg-base-content/20 pointer-events-none max-[360px]:hidden"></div>

  <div class="grid grid-cols-2 max-[360px]:grid-cols-1 gap-3">
    <div class="space-y-2">
      <div class="text-sm font-bold">買う理由</div>
      <% if reason&.purchase_reason.present? %>
        <div class="text-sm whitespace-pre-wrap leading-relaxed"><%= reason.purchase_reason %></div>
      <% else %>
        <div class="text-sm text-base-content/50">まだ記録がありません</div>
      <% end %>
    </div>

    <div class="space-y-2">
      <div class="text-sm font-bold">買わない理由</div>
      <% if reason&.skip_reason.present? %>
        <div class="text-sm whitespace-pre-wrap leading-relaxed"><%= reason.skip_reason %></div>
      <% else %>
        <div class="text-sm text-base-content/50">まだ記録がありません</div>
      <% end %>
    </div>
  </div>
</div>
